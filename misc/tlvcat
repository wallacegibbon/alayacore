#!/usr/bin/env bash
set -euo pipefail

# showtlv — read TLV frames from stdin and print human-readable output
# Format: [2-byte tag][4-byte big-endian length][value]

while true; do
	# Read 6-byte header (2 tag + 4 length)
	header=$(dd bs=6 count=1 2>/dev/null | xxd -p)
	[ -z "$header" ] && break

	tag=$(echo "$header" | head -c4 | xxd -r -p)
	len=$((16#$(echo "$header" | tail -c9 | head -c8)))

	printf "%s\t" "$tag"

	if [ "$len" -gt 0 ]; then
		# Read and output value (binary-safe via dd + xxd)
		dd bs="$len" count=1 2>/dev/null | xxd -p | xxd -r -p
	fi

	echo
done
